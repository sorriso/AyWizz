# =============================================================================
# File: Dockerfile.ui
# Version: 1
# Path: infra/docker/Dockerfile.ui
# Description: Production image for the Next.js UI (`ay_platform_ui/`).
#              Multi-stage build leveraging Next.js 16's `output:
#              "standalone"` mode — the runtime stage carries only the
#              minimal server bundle + static assets, no source tree
#              and no devDependencies.
#
#              Build context is the monorepo ROOT (per CLAUDE.md §4.5),
#              same convention as `Dockerfile.api`. The two images are
#              built side by side from the same context by the
#              `ci-build-images.yml` workflow.
#
#              Runtime config (`/app/public/runtime-config.json`) is
#              shipped with a placeholder ; K8s mounts a ConfigMap
#              over that path so the API URL can be changed PER
#              ENVIRONMENT WITHOUT REBUILDING this image.
# =============================================================================

ARG NODE_VERSION=25-alpine

# ----------------------------------------------------------------------------
# Builder stage : install ALL deps (incl. dev) + run `next build`.
# ----------------------------------------------------------------------------
FROM node:${NODE_VERSION} AS builder

LABEL stage="builder"

WORKDIR /app

# 1. Install dependencies first so the layer is cached when only source
#    changes. `npm ci` requires a lockfile ; we copy both package.json
#    and package-lock.json (when present — first build may not have it).
COPY ay_platform_ui/package.json ay_platform_ui/package-lock.json* ./
# `--include=dev` keeps tailwindcss / typescript / biome available for
# `next build`. `--no-audit --no-fund` cuts CI noise.
RUN npm ci --include=dev --no-audit --no-fund

# 2. Copy source + build.
COPY ay_platform_ui/ ./
RUN npm run build


# ----------------------------------------------------------------------------
# Runtime stage : minimal Node image carrying only standalone bundle +
# static assets. ~100 MB vs ~500 MB for a full node_modules build.
# ----------------------------------------------------------------------------
FROM node:${NODE_VERSION} AS runtime

# Static OCI image labels for the GHCR / Docker Hub package page.
LABEL org.opencontainers.image.title="AyWizz UI" \
      org.opencontainers.image.description="Next.js 16 frontend for the AyWizz platform. Boots from a runtime-config.json (mountable as a K8s ConfigMap) so the API URL, brand and feature flags change WITHOUT rebuilding the image — single image, N environments." \
      org.opencontainers.image.vendor="AyWizz" \
      org.opencontainers.image.licenses="Proprietary" \
      org.opencontainers.image.source="https://github.com/Sorriso/AyWizz" \
      org.opencontainers.image.documentation="https://github.com/Sorriso/AyWizz/blob/main/requirements/050-ARCHITECTURE-OVERVIEW.md"

ENV NODE_ENV=production \
    PORT=3000 \
    # Bind on all interfaces so the K8s Service can route traffic in.
    HOSTNAME=0.0.0.0

WORKDIR /app

# Standalone output is self-contained except for the public/ + static
# directories which Next.js doesn't copy in for legacy reasons.
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

# `node` user (uid=1000) ships in node:alpine ; use it instead of root.
USER node

EXPOSE 3000

# `server.js` is the entry point produced by `output: "standalone"`.
CMD ["node", "server.js"]
