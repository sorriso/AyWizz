# =============================================================================
# File: .env.secret
# Version: 1
# Path: infra/k8s/overlays/system-test/.env.secret
# Description: Credentials for the K8s system-tests overlay. SAME shape
#              as `overlays/dev/.env.secret` — values are deliberately
#              static so test runs are reproducible (a flaky JWT secret
#              is the last thing we need on a CI failure).
#
#              These are TEST PLACEHOLDERS — never used outside the
#              kind cluster spawned by the system-tests wrapper.
# =============================================================================

# Backend bootstrap admin (consumed by *_init Jobs only).
ARANGO_ROOT_PASSWORD=arango-root-test-password
MINIO_ROOT_PASSWORD=minio-root-test-password

# App runtime credentials.
ARANGO_PASSWORD=ay-app-test-password
MINIO_SECRET_KEY=ay-app-test-password

# C2 — Auth Service
C2_JWT_SECRET_KEY=system-test-secret-min-32-chars!!
C2_LOCAL_ADMIN_PASSWORD=seed-password
C2_LOCAL_TENANT_MANAGER_PASSWORD=seed-tm-password

# Production observability.
OBS_ELASTICSEARCH_PASSWORD=
