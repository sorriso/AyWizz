# =============================================================================
# File: .env.secret
# Version: 1
# Path: infra/k8s/overlays/dev/.env.secret
# Description: Source of CREDENTIAL parameters for the K8s dev overlay.
#              Consumed by Kustomize `secretGenerator` to produce the
#              Secret `aywizz-secrets` mounted by every Deployment via
#              `envFrom`.
#
#              These are DEV PLACEHOLDERS — never copy them to staging
#              or production. Production overlays SHALL source secrets
#              from External Secrets Operator + Azure Key Vault (or
#              equivalent), not from a checked-in file.
#
#              Tier-2 sensitivity per CLAUDE.md §4.6 — the file is
#              currently checked in because the values are throwaway
#              dev defaults. Rotate before any non-local exposure.
# =============================================================================

# Backend bootstrap admin (consumed by *_init Jobs only).
ARANGO_ROOT_PASSWORD=arango-root-dev-password
MINIO_ROOT_PASSWORD=minio-root-dev-password

# App runtime credentials.
ARANGO_PASSWORD=ay-app-dev-password
MINIO_SECRET_KEY=ay-app-dev-password

# C2 — Auth Service
C2_JWT_SECRET_KEY=local-dev-secret-min-32-chars!!!!
C2_LOCAL_ADMIN_PASSWORD=seed-password

# Production observability — workflow synthesis (R-100-124).
OBS_ELASTICSEARCH_PASSWORD=
