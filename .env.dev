# =============================================================================
# File: .env.dev
# Version: 15
# Path: .env.dev
# Description: OVERRIDE env file for the local manual-test stack. Used
#              alongside `ay_platform_core/tests/.env.test` via
#              `e2e_stack.sh dev` (multiple --env-file flags ; later
#              files override earlier ones).
#
#              This file ONLY contains the dev-mode flips ; all the
#              shared defaults (Arango / MinIO / per-component config)
#              come from `.env.test`. Keeping the deltas isolated here
#              keeps the test stack deterministic for pytest while
#              giving the operator a one-flag toggle for the manual
#              browser-driven workflow.
#
#              Tier 1 (versioned, non-secret per CLAUDE.md §4.6) :
#              every value here is a well-known dev placeholder. NEVER
#              add real production credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# Demo seed — pre-provision a complete test scenario at C2 startup :
# 1 tenant + 4 users + 1 project + 2 grants. Idempotent.
# -----------------------------------------------------------------------------
C2_DEMO_SEED_ENABLED=true

# -----------------------------------------------------------------------------
# UX dev mode — surface the demo credentials on /ux/config so the
# Next.js login page renders the auto-fill panel. Independent of
# C2_DEMO_SEED_ENABLED (defense-in-depth) — production deployments
# leave both flags False.
# -----------------------------------------------------------------------------
C2_UX_DEV_MODE_ENABLED=true

# -----------------------------------------------------------------------------
# C3 → C7 wiring : enable RAG-augmented chat. With this set, C3
# calls C7 for retrieval on every user message before invoking C8
# (mock LLM in the test stack). Without it, C3 returns a "RAG/LLM
# not wired" stub. Pytest e2e leaves this empty in .env.test to
# keep the auth-matrix deterministic ; the dev stack flips it on.
# -----------------------------------------------------------------------------
C3_C7_BASE_URL=http://c7:8000
# C3 → C4 documents surface for the chat-direct DocGen tool loop
# (D-015 / Phase 2.C.2). Set in the dev stack so the assistant can
# create/update documents during a conversation. Pytest e2e leaves
# this empty (.env.test) so the tool loop stays off and the
# auth-matrix remains deterministic.
C3_C4_BASE_URL=http://c4:8000

# -----------------------------------------------------------------------------
# Real LLM chain : route C8 to Anthropic's OpenAI-COMPATIBILITY
# endpoint. Journey (2026-05-19) : 4 local Ollama models all failed
# the agentic DocGen tool loop (qwen2.5:3b `,,` JSON ;
# qwen2.5-coder:7b refused read→update ; llama3.1:8b `parameters`-key
# + corrupted content ; hermes3:8b asked permission) AND ran
# ~4 min/turn on CPU ; Gemini free unavailable on this Google account
# (limit:0 / 404) ; OpenRouter `:free` worked structurally but
# throttled (429) mid tool-loop. Operator then provisioned a paid
# Anthropic API key. Anthropic exposes an OpenAI-compatible surface
# at `https://api.anthropic.com/v1` (POST /chat/completions, auth
# `Authorization: Bearer <ANTHROPIC_KEY>`, model `claude-*`, tools
# mapped) — so the existing OpenAI-shaped C8 client works UNCHANGED.
# Claude is strong at structured multi-step tool use → reliable
# read→update chaining. URL + model are Tier-1 here ; the key is the
# Tier-2 secret `C3_C8_BEARER_TOKEN` (.env.secret). Pytest e2e keeps
# mock_llm in .env.test ; Ollama/OpenRouter remain fallbacks (revert
# these two lines). httpx concatenates "/chat/completions" onto the
# base (validated via the Ollama `/v1/chat/completions` access log).
# COST : this is a PAID API — every DocGen turn bills tokens.
# -----------------------------------------------------------------------------
C8_GATEWAY_URL=https://api.anthropic.com/v1
# claude-haiku-4-5 : cost-optimised for the DocGen tool-loop —
# strong structured tool-calling at a fraction of Sonnet's price
# (operator switched from claude-sonnet-4-6 to cut the dev bill,
# 2026-05-19). Bump back to claude-sonnet-4-6 if a turn needs more
# reasoning depth than Haiku delivers.
C8_DEFAULT_MODEL=claude-haiku-4-5
# Bump the request timeout : Ollama on CPU (Mac mini i3) often needs
# more than the 60 s default to produce the verbose JSON envelope
# the C4 orchestrator asks for — especially on the first call after
# a cold model load. qwen2.5-coder:7b on CPU is ~2-3x slower per
# token than a 3b and the DocGen tool loop chains several rounds, so
# 600 s avoids a spurious timeout masking the model's real output.
# Pytest e2e keeps the 60 s default (mock_llm responses are instant).
C8_REQUEST_TIMEOUT_SECONDS=600.0
