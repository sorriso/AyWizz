# =============================================================================
# File: .env.example
# Version: 3
# Path: .env.example
# Description: Single canonical env file template (per R-100-110 v2).
#
#              Three credential classes per R-100-118 v2:
#                (a) Backend bootstrap admin (`*_ROOT_*`) — used ONLY by
#                    the init containers to create the app users.
#                (b) App runtime credentials (`ARANGO_USERNAME` /
#                    `ARANGO_PASSWORD` / `MINIO_ACCESS_KEY` /
#                    `MINIO_SECRET_KEY`) — read by every Settings class
#                    via validation_alias. NEVER root.
#                (c) Application admin (`C2_LOCAL_ADMIN_*`) —
#                    bootstrapped by C2 in AUTH_MODE=local; ignored
#                    otherwise.
#
#              Coherence: tests/coherence/test_env_completeness.py
#              enforces every Settings field has exactly one line here,
#              and every line either maps to a Settings field or belongs
#              to the documented infra-bootstrap whitelist.
#
#              Copy this file to `.env` for a dev workstation or to
#              `ay_platform_core/tests/.env.test` for the test stack.
#              REPLACE every `change-me-*` value before any non-local use.
# =============================================================================

# -----------------------------------------------------------------------------
# Platform-wide
# -----------------------------------------------------------------------------
PLATFORM_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# (a) Backend bootstrap admin — used ONLY by init containers.
#     The arangodb / minio services receive these via Compose ${VAR}
#     substitution; the *_init one-shots receive them via env_file.
# -----------------------------------------------------------------------------
ARANGO_ROOT_PASSWORD=change-me-arango-root-password
ARANGO_ROOT_USERNAME=root
MINIO_ROOT_PASSWORD=change-me-minio-root-password
MINIO_ROOT_USER=minioadmin

# Host-published ports — R-100-122 §10.7. Base 56000.
# Override these per-deployment if 56xxx happens to collide on a
# specific operator's machine; the spec only cares that components
# follow the BASE+offset scheme, not the absolute value.
PORT_C1_DASHBOARD=56080
PORT_C1_PUBLIC=56000
PORT_MOCK_LLM=59800
PORT_OBSERVABILITY=59900

# -----------------------------------------------------------------------------
# (b) Shared infrastructure — APP runtime credentials (NEVER root).
# -----------------------------------------------------------------------------
ARANGO_DB=platform
ARANGO_PASSWORD=change-me-arango-app-password
ARANGO_URL=http://arangodb:8529
ARANGO_USERNAME=ay_app
LOG_FORMAT=json
LOG_LEVEL=INFO
MINIO_ACCESS_KEY=ay_app
MINIO_ENDPOINT=minio:9000
MINIO_SECRET_KEY=change-me-minio-app-password
MINIO_SECURE=false
OLLAMA_URL=http://ollama:11434
TRACE_SAMPLE_RATE=1.0

# -----------------------------------------------------------------------------
# C2 — Auth Service
#
# (c) C2_LOCAL_ADMIN_* — pre-existing admin user bootstrapped by C2
#     lifespan when C2_AUTH_MODE=local. Ignored in 'none' / 'sso'.
#     R-100-118 v2.
# -----------------------------------------------------------------------------
C2_AUTH_MODE=none
C2_JWT_ALGORITHM=HS256
C2_JWT_PRIVATE_KEY=
C2_JWT_PUBLIC_KEY=
C2_JWT_SECRET_KEY=change-me-in-production-min-32-chars!!
C2_LOCAL_ADMIN_PASSWORD=change-me-c2-local-admin-password
C2_LOCAL_ADMIN_USERNAME=admin
C2_TOKEN_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# C4 — Orchestrator
# -----------------------------------------------------------------------------
C4_DISPATCHER_BACKEND=in-process
C4_ENRICHMENT_ROUND_CAP=3
C4_FIX_ATTEMPT_CAP=3
C4_MINIO_BUCKET=orchestrator
C4_SUB_AGENT_TIMEOUT_SECONDS=900

# -----------------------------------------------------------------------------
# C5 — Requirements Service
# -----------------------------------------------------------------------------
C5_IDEMPOTENCY_TTL_SECONDS=86400
C5_MINIO_BUCKET=requirements
C5_RECONCILE_INTERVAL_SECONDS=900

# -----------------------------------------------------------------------------
# C6 — Validation Pipeline Registry
# -----------------------------------------------------------------------------
C6_DEFAULT_CHECK_ENABLED=true
C6_MAX_FINDINGS_PER_RUN=5000
C6_MINIO_BUCKET=validation

# -----------------------------------------------------------------------------
# C7 — Memory Service
#
# Embedding adapter: production default is `ollama` running `all-minilm`
# (384-dim, ~46 MB). The `deterministic-hash` adapter is reserved for
# unit tests where embedding quality is irrelevant — it produces
# bag-of-words vectors that do NOT support real semantic retrieval.
# Switching adapters is an architectural decision (CLAUDE.md §4.6) —
# track in SESSION-STATE §3.
# -----------------------------------------------------------------------------
C7_CHUNK_OVERLAP=64
C7_CHUNK_TOKEN_SIZE=512
C7_DEFAULT_QUOTA_BYTES=1073741824
C7_EMBEDDING_ADAPTER=ollama
C7_EMBEDDING_DIMENSION=384
C7_EMBEDDING_MODEL_ID=all-minilm
C7_EMBEDDING_OLLAMA_TIMEOUT_S=30.0
C7_KG_EXPANSION_BOOST=1.3
C7_KG_EXPANSION_DEPTH=1
C7_KG_EXPANSION_NEIGHBOUR_CAP=20
C7_MAX_UPLOAD_BYTES=52428800
C7_MINIO_BUCKET=memory
C7_RETRIEVAL_SCAN_CAP=50000

# -----------------------------------------------------------------------------
# C8 — LLM Gateway (client-side)
# -----------------------------------------------------------------------------
C8_CONNECT_TIMEOUT_SECONDS=5.0
C8_GATEWAY_URL=http://c8:8000/v1
C8_REQUEST_TIMEOUT_SECONDS=60.0
C8_SSE_HEARTBEAT_SECONDS=15.0

# -----------------------------------------------------------------------------
# C9 — MCP Server
# -----------------------------------------------------------------------------
C9_C5_BASE_URL=http://c5_requirements:8000
C9_C6_BASE_URL=http://c6_validation:8000
C9_HTTP_TIMEOUT_SECONDS=10.0
C9_MAX_TOOL_ARGS_BYTES=256000
C9_PROTOCOL_VERSION=2025-03-26
C9_SERVER_NAME=ay-platform-core
C9_SERVER_VERSION=1.0.0

# -----------------------------------------------------------------------------
# _observability — test-tier log collector (R-100-120). Underscore prefix
# marks the module as test-only; production K8s manifests SHALL NOT
# deploy it (R-100-121).
# -----------------------------------------------------------------------------
OBS_BUFFER_SIZE_PER_SERVICE=5000
OBS_DOCKER_SOCKET_PATH=/var/run/docker.sock
OBS_SERVICE_FILTER_PREFIX=ay-

# -----------------------------------------------------------------------------
# observability/workflow — production-tier workflow synthesis (R-100-124).
# `OBS_SPAN_SOURCE` selects the SpanSource backend at runtime: `buffer` is
# the in-process source used by the test-tier collector; `loki` and
# `elasticsearch` are the production options (mountable router consumes
# the same algorithm regardless of backend).
# -----------------------------------------------------------------------------
OBS_SPAN_SOURCE=buffer
OBS_LOKI_URL=http://loki:3100
OBS_LOKI_LABEL_SELECTOR={container=~"ay-.*"}
OBS_ELASTICSEARCH_URL=http://elasticsearch:9200
OBS_ELASTICSEARCH_INDEX=ay-logs-*
OBS_ELASTICSEARCH_USERNAME=
OBS_ELASTICSEARCH_PASSWORD=
OBS_QUERY_WINDOW_HOURS=24
OBS_REQUEST_TIMEOUT_SECONDS=10
OBS_FETCH_LIMIT=5000
