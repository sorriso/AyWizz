# =============================================================================
# File: .env.example
# Version: 2
# Path: ay_platform_ui/.env.example
# Description: Local-dev environment for the Next.js UI. Copy to
#              `.env.local` to activate.
#
#              v2 (2026-04-29): clarifies that this var is BUILD-TIME
#              (Next.js dev rewrites only). The API base URL the UX
#              uses AT RUNTIME comes from `public/runtime-config.json`
#              (deployment-time, mountable as a K8s ConfigMap, no
#              rebuild required).
#
#              Deployment matrix:
#                DEV (compose stack)   → keep this var pointing at
#                  Traefik ; runtime-config.json has empty apiBaseUrl
#                  ; browser sees same-origin via dev rewrites.
#                PROD K8s (same-origin) → this var unused (no Next.js
#                  dev server runs) ; runtime-config.json has empty
#                  apiBaseUrl ; Traefik handles routing.
#                PROD cross-origin → set runtime-config.json
#                  apiBaseUrl to the public API URL ; this var still
#                  unused.
# =============================================================================

# Traefik public entry of the docker-compose stack (DEV ONLY — informs
# the dev-server rewrites in next.config.ts). R-100-122 default = 56000.
NEXT_PUBLIC_PLATFORM_BASE_URL=http://localhost:56000
