# =============================================================================
# File: .env.example
# Version: 1
# Path: ay_platform_ui/.env.example
# Description: Local-dev environment for the Next.js UI. Copy to `.env.local`
#              to activate. The UI NEVER talks directly to a component — all
#              traffic goes through Traefik on this URL.
# =============================================================================

# Traefik public entry of the docker-compose stack.
NEXT_PUBLIC_PLATFORM_BASE_URL=http://localhost
