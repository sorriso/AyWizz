# =============================================================================
# File: .env.test
# Version: 3
# Path: ay_platform_core/tests/.env.test
# Description: Single env file for the docker-compose test stack (per
#              R-100-110 v2). Each variable appears exactly once.
#
#              Three credential classes per R-100-118 v2:
#                (a) Backend bootstrap admin (`*_ROOT_*`) — used ONLY by
#                    the init containers (arangodb_init, minio_init).
#                    Consumed by the arangodb / minio services themselves
#                    via Compose `${VAR}` substitution (e2e_stack.sh up
#                    passes --env-file).
#                (b) App runtime (`ARANGO_USERNAME` / `ARANGO_PASSWORD`,
#                    `MINIO_ACCESS_KEY` / `MINIO_SECRET_KEY`) — read by
#                    every Python Settings class via validation_alias;
#                    NEVER root.
#                (c) Application admin (`C2_LOCAL_ADMIN_*`) — bootstrapped
#                    by C2 lifespan when AUTH_MODE=local; ignored in
#                    AUTH_MODE=none/sso.
#
#              Coherence: tests/coherence/test_env_completeness.py
#              enforces (i) every Settings field has a line here, (ii)
#              every line either maps to a Settings field or belongs to
#              the documented infra-bootstrap whitelist.
#
#              Keep alphabetical within each block for diff readability.
# =============================================================================

# -----------------------------------------------------------------------------
# Platform-wide
# -----------------------------------------------------------------------------
PLATFORM_ENVIRONMENT=testing

# -----------------------------------------------------------------------------
# (a) Backend bootstrap admin — used ONLY by init containers.
#     NOT mapped to any Pydantic Settings field (whitelisted in the
#     coherence test). Consumed via Compose ${VAR} substitution by the
#     `arangodb` and `minio` services and via env_file by the *_init
#     one-shots.
# -----------------------------------------------------------------------------
ARANGO_ROOT_PASSWORD=arango-root-dev-password
ARANGO_ROOT_USERNAME=root
MINIO_ROOT_PASSWORD=minio-root-dev-password
MINIO_ROOT_USER=minioadmin

# Host-published ports — schema per R-100-122 §10.7. Base 56000 (high
# range, avoids collisions with 80/443/8080/3000/5432/8000/8080).
# C1 public  = BASE + 0       = 56000
# C1 dashboard = BASE + 80    = 56080
# Cn direct (debug-only, override)  = BASE + n*100  (56100..56900)
# Backends (reserved)         = BASE + 1000+      (57000..57300)
# Test sidecars (BASE + 9000+ = 59000..59999)
#   _mock_llm admin           = BASE + 9800       = 59800
#   _observability            = BASE + 9900       = 59900
PORT_C1_DASHBOARD=56080
PORT_C1_PUBLIC=56000
PORT_MOCK_LLM=59800
PORT_OBSERVABILITY=59900

# -----------------------------------------------------------------------------
# (b) Shared infrastructure — APP runtime credentials (NEVER root).
#     Read by every component without prefix via validation_alias.
# -----------------------------------------------------------------------------
ARANGO_DB=platform
ARANGO_PASSWORD=ay-app-dev-password
ARANGO_URL=http://arangodb:8529
ARANGO_USERNAME=ay_app
LOG_FORMAT=json
LOG_LEVEL=INFO
MINIO_ACCESS_KEY=ay_app
MINIO_ENDPOINT=minio:9000
MINIO_SECRET_KEY=ay-app-dev-password
MINIO_SECURE=false
OLLAMA_URL=http://ollama:11434
TRACE_SAMPLE_RATE=1.0

# -----------------------------------------------------------------------------
# C2 — Auth Service
#
# (c) Application admin: C2_LOCAL_ADMIN_* — pre-existing admin user
#     bootstrapped by C2 lifespan when C2_AUTH_MODE=local. Ignored in
#     'none' (default for tests) and 'sso' modes; still declared here
#     so the env file is exhaustive (R-100-110 v2). R-100-118 v2.
# -----------------------------------------------------------------------------
C2_AUTH_MODE=local
C2_JWT_ALGORITHM=HS256
C2_JWT_PRIVATE_KEY=
C2_JWT_PUBLIC_KEY=
C2_JWT_SECRET_KEY=local-dev-secret-min-32-chars!!!!
# Bootstrap admin used by both the seeder (`scripts/seed_e2e.py`) and the
# system-test fixtures (`tests/system/conftest.py::admin_token`). Both
# perform `POST /auth/login` with username=alice / password=seed-password,
# so the C2 lifespan MUST create the user with the same identity. The
# `_ensure_local_admin()` function reads C2_LOCAL_ADMIN_* and grants the
# global `admin` role — which is what unblocks C5's project-scoped route
# permission checks (`requires one of: project_editor, project_owner,
# admin`).
C2_LOCAL_ADMIN_PASSWORD=seed-password
C2_LOCAL_ADMIN_USERNAME=alice
C2_TOKEN_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# C4 — Orchestrator
# -----------------------------------------------------------------------------
C4_DISPATCHER_BACKEND=in-process
C4_ENRICHMENT_ROUND_CAP=3
C4_FIX_ATTEMPT_CAP=3
C4_MINIO_BUCKET=orchestrator
C4_SUB_AGENT_TIMEOUT_SECONDS=900

# -----------------------------------------------------------------------------
# C5 — Requirements Service
# -----------------------------------------------------------------------------
C5_IDEMPOTENCY_TTL_SECONDS=86400
C5_MINIO_BUCKET=requirements
C5_RECONCILE_INTERVAL_SECONDS=900

# -----------------------------------------------------------------------------
# C6 — Validation Pipeline Registry
# -----------------------------------------------------------------------------
C6_DEFAULT_CHECK_ENABLED=true
C6_MAX_FINDINGS_PER_RUN=5000
C6_MINIO_BUCKET=validation

# -----------------------------------------------------------------------------
# C7 — Memory Service
# -----------------------------------------------------------------------------
C7_CHUNK_OVERLAP=64
C7_CHUNK_TOKEN_SIZE=512
C7_DEFAULT_QUOTA_BYTES=1073741824
C7_EMBEDDING_ADAPTER=ollama
C7_EMBEDDING_DIMENSION=384
C7_EMBEDDING_MODEL_ID=all-minilm
C7_EMBEDDING_OLLAMA_TIMEOUT_S=30.0
C7_MAX_UPLOAD_BYTES=52428800
C7_MINIO_BUCKET=memory
C7_RETRIEVAL_SCAN_CAP=50000

# -----------------------------------------------------------------------------
# C8 — LLM Gateway client (points at the mock LLM in the test stack)
# -----------------------------------------------------------------------------
C8_CONNECT_TIMEOUT_SECONDS=5.0
C8_GATEWAY_URL=http://mock_llm:8000/v1
C8_REQUEST_TIMEOUT_SECONDS=60.0
C8_SSE_HEARTBEAT_SECONDS=15.0

# -----------------------------------------------------------------------------
# C9 — MCP Server
# -----------------------------------------------------------------------------
C9_C5_BASE_URL=http://c5:8000
C9_C6_BASE_URL=http://c6:8000
C9_HTTP_TIMEOUT_SECONDS=10.0
C9_MAX_TOOL_ARGS_BYTES=256000
C9_PROTOCOL_VERSION=2025-03-26
C9_SERVER_NAME=ay-platform-core
C9_SERVER_VERSION=1.0.0

# -----------------------------------------------------------------------------
# _observability — test-tier log collector (R-100-120). NOT a platform
# component; the underscore prefix marks it as test-only.
# -----------------------------------------------------------------------------
OBS_BUFFER_SIZE_PER_SERVICE=5000
OBS_DOCKER_SOCKET_PATH=/var/run/docker.sock
OBS_SERVICE_FILTER_PREFIX=ay-

# -----------------------------------------------------------------------------
# observability/workflow — production-tier workflow synthesis (R-100-124).
# Test stack uses `buffer` (the test-tier `_observability` owns its own
# LogRingBuffer); the loki/elasticsearch fields document the production
# defaults and stay inert when SPAN_SOURCE=buffer.
# -----------------------------------------------------------------------------
OBS_SPAN_SOURCE=buffer
OBS_LOKI_URL=http://loki:3100
OBS_LOKI_LABEL_SELECTOR={container=~"ay-.*"}
OBS_ELASTICSEARCH_URL=http://elasticsearch:9200
OBS_ELASTICSEARCH_INDEX=ay-logs-*
OBS_ELASTICSEARCH_USERNAME=
OBS_ELASTICSEARCH_PASSWORD=
OBS_QUERY_WINDOW_HOURS=24
OBS_REQUEST_TIMEOUT_SECONDS=10
OBS_FETCH_LIMIT=5000
