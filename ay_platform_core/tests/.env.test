# =============================================================================
# File: .env.test
# Version: 1
# Path: ay_platform_core/tests/.env.test
# Description: Environment file consumed by the docker-compose test stack
#              (ay_platform_core/tests/docker-compose.yml). Holds values
#              tuned for the test environment — container-hostnames for
#              Arango/MinIO, distinct logical DBs per component, a known
#              JWT secret, etc.
#
#              Coherence: every variable listed here must correspond to a
#              field of some BaseSettings subclass in src/ (enforced by
#              tests/coherence/test_env_completeness.py). Conversely,
#              every settings field must appear here.
#
#              Keep alphabetical within each component block for diff
#              readability.
# =============================================================================

# -----------------------------------------------------------------------------
# Platform-wide
# -----------------------------------------------------------------------------
PLATFORM_ENVIRONMENT=testing

# -----------------------------------------------------------------------------
# C2 — Auth Service
# -----------------------------------------------------------------------------
C2_ARANGO_DB_NAME=c2
C2_ARANGO_PASSWORD=password
C2_ARANGO_URL=http://arangodb:8529
C2_ARANGO_USERNAME=root
C2_AUTH_MODE=none
C2_JWT_ALGORITHM=HS256
C2_JWT_PRIVATE_KEY=
C2_JWT_PUBLIC_KEY=
C2_JWT_SECRET_KEY=local-dev-secret-min-32-chars!!!!
C2_TOKEN_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# C3 — Conversation Service
# -----------------------------------------------------------------------------
C3_ARANGO_DB=c3
C3_ARANGO_HOST=arangodb
C3_ARANGO_PASSWORD=password
C3_ARANGO_PORT=8529
C3_ARANGO_USER=root

# -----------------------------------------------------------------------------
# C4 — Orchestrator
# -----------------------------------------------------------------------------
C4_ARANGO_DB=c4
C4_ARANGO_HOST=arangodb
C4_ARANGO_PASSWORD=password
C4_ARANGO_PORT=8529
C4_ARANGO_USER=root
C4_DISPATCHER_BACKEND=in-process
C4_ENRICHMENT_ROUND_CAP=3
C4_FIX_ATTEMPT_CAP=3
C4_MINIO_ACCESS_KEY=minioadmin
C4_MINIO_BUCKET=orchestrator
C4_MINIO_ENDPOINT=minio:9000
C4_MINIO_SECRET_KEY=minioadmin
C4_MINIO_SECURE=false
C4_SUB_AGENT_TIMEOUT_SECONDS=900

# -----------------------------------------------------------------------------
# C5 — Requirements Service
# -----------------------------------------------------------------------------
C5_ARANGO_DB=c5
C5_ARANGO_HOST=arangodb
C5_ARANGO_PASSWORD=password
C5_ARANGO_PORT=8529
C5_ARANGO_USER=root
C5_IDEMPOTENCY_TTL_SECONDS=86400
C5_MINIO_ACCESS_KEY=minioadmin
C5_MINIO_BUCKET=requirements
C5_MINIO_ENDPOINT=minio:9000
C5_MINIO_SECRET_KEY=minioadmin
C5_MINIO_SECURE=false
C5_RECONCILE_INTERVAL_SECONDS=900

# -----------------------------------------------------------------------------
# C6 — Validation Pipeline Registry
# -----------------------------------------------------------------------------
C6_ARANGO_DB=c6
C6_ARANGO_HOST=arangodb
C6_ARANGO_PASSWORD=password
C6_ARANGO_PORT=8529
C6_ARANGO_USER=root
C6_DEFAULT_CHECK_ENABLED=true
C6_MAX_FINDINGS_PER_RUN=5000
C6_MINIO_ACCESS_KEY=minioadmin
C6_MINIO_BUCKET=validation
C6_MINIO_ENDPOINT=minio:9000
C6_MINIO_SECRET_KEY=minioadmin
C6_MINIO_SECURE=false

# -----------------------------------------------------------------------------
# C7 — Memory Service
# -----------------------------------------------------------------------------
C7_ARANGO_DB=c7
C7_ARANGO_HOST=arangodb
C7_ARANGO_PASSWORD=password
C7_ARANGO_PORT=8529
C7_ARANGO_USER=root
C7_CHUNK_OVERLAP=64
C7_CHUNK_TOKEN_SIZE=512
C7_DEFAULT_QUOTA_BYTES=1073741824
C7_EMBEDDING_ADAPTER=deterministic-hash
C7_EMBEDDING_DIMENSION=128
C7_EMBEDDING_MODEL_ID=deterministic-hash-v1
C7_EMBEDDING_OLLAMA_TIMEOUT_S=30.0
C7_EMBEDDING_OLLAMA_URL=http://ollama:11434
C7_MINIO_ACCESS_KEY=minioadmin
C7_MINIO_BUCKET=memory
C7_MINIO_ENDPOINT=minio:9000
C7_MINIO_SECRET_KEY=minioadmin
C7_MINIO_SECURE=false
C7_RETRIEVAL_SCAN_CAP=50000

# -----------------------------------------------------------------------------
# C8 — LLM Gateway client (points at the mock-LLM stand-in in the test stack)
# -----------------------------------------------------------------------------
C8_CONNECT_TIMEOUT_SECONDS=5.0
C8_GATEWAY_URL=http://mock_llm:8000/v1
C8_REQUEST_TIMEOUT_SECONDS=60.0
C8_SSE_HEARTBEAT_SECONDS=15.0

# -----------------------------------------------------------------------------
# C9 — MCP Server
# -----------------------------------------------------------------------------
C9_C5_BASE_URL=http://c5:8000
C9_C6_BASE_URL=http://c6:8000
C9_HTTP_TIMEOUT_SECONDS=10.0
C9_MAX_TOOL_ARGS_BYTES=256000
C9_PROTOCOL_VERSION=2025-03-26
C9_SERVER_NAME=ay-platform-core
C9_SERVER_VERSION=1.0.0
